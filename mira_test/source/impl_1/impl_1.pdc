# guesstimate clock uncertainty at about 1% of period
# set setup time to 3x 1% to be conservative
# large uncertainty in hold time results in PAR fail
set_clock_uncertainty -setup 0.30 [get_clocks ClkxC]
set_clock_uncertainty -hold  0.10 [get_clocks ClkxC]

# Force use of correct MIPI DPHY
ldc_set_location -site {DPHY0} [get_cells mipi_rx_inst/mipi_dphy_rx_inst/lscc_mipi_dphy_inst/RECEIVER.lscc_mipi_wrapper_rx/HARD_IP.CIL.u_dphy_cil.DPHY_inst]